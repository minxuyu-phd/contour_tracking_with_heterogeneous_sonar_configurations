    <!-- <world_transform rpy="0.0 0.0 -2.8" xyz="-10.0 110.0 5.0"/> -->
    <!-- for island02 -->
    <!-- <world_transform rpy="0.0 0.0 -2.8" xyz="-10.0 120.0 5.0"/> -->
    <!-- for island03 -->
    <world_transform rpy="0.0 0.0 2.5" xyz="30.0 120.0 5.0"/>
</robot>
</scenario>
